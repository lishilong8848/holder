# 证书查询系统环境变量配置示例

# 服务端口
PORT=58000

# 默认并发数 (建议 2-3，根据内存调整)
DEFAULT_CONCURRENCY=3

# 飞书默认配置 (可选，如果不传递则从此处读取)
FEISHU_APP_ID=cli_a9d1c9fe9d381cee
FEISHU_APP_SECRET=PCZSOMI9ITqFWUkqT5TtQcVljP0Sx48y
# FEISHU_APP_TOKEN=X9CwbB3zhaLK7JsQZVZcFR9fnTf
# FEISHU_TABLE_ID=tblWHIbp172MNjM1

# Chrome 路径配置 (如果系统环境变量未设置，请在此指定)
# CHROME_BIN=C:\Program Files\Google\Chrome\Application\chrome.exe
# CHROMEDRIVER_PATH=D:\drivers\chromedriver.exe

# 飞书群消息监听配置 (需要在飞书开发者后台开启"使用长连接接收事件"并订阅 im.message.receive_v1)
# FEISHU_APP_ID 和 FEISHU_APP_SECRET 同上，复用即可
# 群名1,群名2  (多个群名用英文逗号分隔，留空则监听所有群)

FEISHU_WATCH_GROUPS=查询证件测试群