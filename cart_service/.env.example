# 证书查询系统环境变量配置示例

# 服务端口
PORT=58000

# 默认并发数 (建议 2-3，根据内存调整)
DEFAULT_CONCURRENCY=3

# 飞书默认配置 (可选，如果不传递则从此处读取)
# FEISHU_APP_ID=你的APP_ID
# FEISHU_APP_SECRET=你的APP_SECRET
# FEISHU_APP_TOKEN=你的多维表TOKEN
# FEISHU_TABLE_ID=你的表格ID

# Chrome 路径配置 (如果系统环境变量未设置，请在此指定)
# CHROME_BIN=C:\Program Files\Google\Chrome\Application\chrome.exe
# CHROMEDRIVER_PATH=D:\drivers\chromedriver.exe
